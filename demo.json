{
  "name": "demo_rule",
  "baseUrl": "https://www.example.com",
  "encoding": "utf-8",
  "mode": "chapter",
  "book": {
    "title": "#info h1",
    "author": "#info p:nth-child(2)",
    "cover": "#fmimg img @src",
    "description": "#intro"
  },
  "chapterList": {
    "url": "#list a @href",
    "container": "#list",
    "item": "dd a",
    "title": "self::text",
    "href": "self::@href"
  },
  "content": {
    "title": ".bookname h1",
    "body": "#content",
    "nextPage": ".bottem1 a:nth-child(4) @href",
    "filters": ["script", "style", "div[style]"]
  }
}
